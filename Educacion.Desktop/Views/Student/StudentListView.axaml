<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Educacion.Desktop.ViewModels.Student"
             xmlns:models="using:Educacion.Desktop.Models"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Educacion.Desktop.Views.Student.StudentListView"
             x:DataType="vm:StudentListViewModel">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" Margin="0,0,0,20">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Listado de Estudiantes" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Gestiona la información y matrículas de los alumnos." FontSize="14" Foreground="#6B7280"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                    <Button Command="{Binding CreateCommand}" 
                            Background="#2563EB" Foreground="White" 
                            Padding="20,10" CornerRadius="8" FontWeight="SemiBold">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource people_regular}" Width="14" Height="14"/>
                            <TextBlock Text="Nuevo Estudiante"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" BoxShadow="0 4 10 0 #10000000">
            <Grid RowDefinitions="Auto, *">
                
                <Border Grid.Row="0" Background="#F9FAFB" Padding="20,12" CornerRadius="12,12,0,0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="40, 2*, 2*, 1*, Auto">
                        <TextBlock Grid.Column="1" Text="NOMBRE COMPLETO" FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
                        <TextBlock Grid.Column="2" Text="CORREO ELECTRÓNICO" FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
                        <TextBlock Grid.Column="3" Text="ESTADO" FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
                        <TextBlock Grid.Column="4" Text="ACCIONES" FontSize="11" FontWeight="Bold" Foreground="#6B7280"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding Students}" 
                         SelectedItem="{Binding SelectedStudent}"
                         Background="Transparent" BorderThickness="0" Padding="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="20,12"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#F3F4F6"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#F9FAFB"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#EFF6FF"/>
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:Student">
                            <Grid ColumnDefinitions="40, 2*, 2*, 1*, Auto">
                                <Border Grid.Column="0" Width="30" Height="30" Background="#E5E7EB" CornerRadius="15" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FullName[0]}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#4B5563"/>
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding FullName}" VerticalAlignment="Center" FontWeight="Medium" Foreground="#111827"/>
                                <TextBlock Grid.Column="2" Text="{Binding Email}" VerticalAlignment="Center" Foreground="#6B7280"/>
                                
                                <Border Grid.Column="3" HorizontalAlignment="Left" Padding="8,2" CornerRadius="10" Background="#DCFCE7">
                                    <TextBlock Text="Activo" FontSize="10" Foreground="#166534" FontWeight="Bold"/>
                                </Border>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding $parent[UserControl].((vm:StudentListViewModel)DataContext).EditCommand}"
                                            Background="Transparent" BorderThickness="0" Padding="4">
                                        <PathIcon Data="{StaticResource person_board_regular}" Width="14" Foreground="#2563EB"/>
                                    </Button>
                                    <Button Command="{Binding $parent[UserControl].((vm:StudentListViewModel)DataContext).DeleteCommand}"
                                            Background="Transparent" BorderThickness="0" Padding="4">
                                        <PathIcon Data="{StaticResource clipboard_regular}" Width="14" Foreground="#DC2626"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>